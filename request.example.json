{
  "input_path": "./4k.mp4",
  "output_path": "compressed_hevc.mp4",
  "vmaf_threshold": 89,
  "codec": "hevc",
  "codec_mode": "CRF",
  "target_bitrate": null,
  "time_budget_sec": 3000,
  "max_search_steps": 5,
  "max_recipes": 1,
  "max_workers": 3,
  "crf_candidates": 3,
  "crf_spread": 2,
  "use_proxy": true,
  "proxy_seconds_per_segment": 2.5,
  "proxy_max_seconds": 15.0,
  "proxy_min_window_seconds": 0.5,
  "vbr_max_ratio_to_target": 1.1,
  "vbr_min_mbps_floor": 0.5,
  "crf_min": 22,
  "crf_max": 36,
  "crf_start": null,
  "sample_frames": 40,
  "vmaf_n_subsample": 1,
  "vmaf_n_threads": 2,
  "vmaf_backend": "docker",
  "vmaf_docker_image": "vidaio-compression-eval",
  "vmaf_docker_gpus": false,
  "work_dir": "work",
  "keep_candidates": true,
  "ffmpeg_bin": "/usr/bin/ffmpeg",
  "ffprobe_bin": "/usr/bin/ffprobe"
}
