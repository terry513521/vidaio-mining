  "vmaf_threshold": 85,
  "codec_mode": "RC",
  "encoder": "libx265",
  "fleet_batch_size": 5,
  "fleet_gpu_slots": 1,
  "libx265_refine_preset": "fast",
  "libx265_feature_baseline": true,
  "libx265_profile": "main",
  "libx265_params": "aq-mode=2:aq-strength=1:rd=6:ref=6:bframes=12:rc-lookahead=50:keyint=60:min-keyint=1:scenecut=50",
  "libx265_crf_min": 22,
  "libx265_crf_max": 42,
  "crf_start": 30,
  "param_tune": true,
  "param_tune_max_trials": 25,
  "param_tune_no_improve_stop": 10,
  "param_tune_vmaf_headroom": 2.0,
  "param_tune_max_rounds": 4,
  "time_budget_sec": 0,
  "final_encode_reserve_sec": 0,
  "probe_min_budget_sec": 0,
  "crf_search_increment": 1,
  "crf_search_max_encoded_percent": 80.0,
  "crf_search_max_runs": 6,
  "crf_search_near_vmaf_band": 1.5,
  "vmaf_n_subsample": 1,
  "vmaf_n_threads": 40,
  "vmaf_docker_gpus": true,
  "work_dir": "work_fleet"
}
